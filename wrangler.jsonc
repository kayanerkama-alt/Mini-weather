{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mini-weather",
  "compatibility_date": "2026-06-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "/api/forecast",
      "script": "forecast-api.js"
    }
  ]
}
